<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.ImageView?>

<Button mnemonicParsing="false" onAction="#toolClicked" fx:id="toolButton" styleClass="fragment-bordered" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.toolPanel.ModifierToolView">
   <graphic>
      <ImageView fx:id="toolImageView" fitHeight="30.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true" />
   </graphic>
   <tooltip>
      <Tooltip fx:id="toolToolTip" text="Empty Tooltip" />
   </tooltip>
</Button>
