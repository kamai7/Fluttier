<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<SplitPane dividerPositions="0.5" orientation="VERTICAL" styleClass="main" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.toolPanel.ToolPanelView">
   <items>
      <VBox>
         <children>
            <Label text="Modifiers">
               <VBox.margin>
                  <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
               </VBox.margin>
            </Label>
            <Separator prefWidth="200.0" />
            <ScrollPane fx:id="modifiersScrollPane" fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" minHeight="0.0" VBox.vgrow="ALWAYS">
               <content>
                  <FlowPane fx:id="modifiersFlowPane" hgap="8.0" maxHeight="-Infinity" maxWidth="-Infinity" vgap="8.0">
                     <padding>
                        <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                     </padding>
                  </FlowPane>
               </content>
            </ScrollPane>
         </children>
         <padding>
            <Insets left="3.0" right="3.0" />
         </padding>
      </VBox>
      <VBox>
         <children>
            <Label text="Shapes">
               <VBox.margin>
                  <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
               </VBox.margin>
            </Label>
            <Separator prefWidth="200.0" />
            <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" minHeight="0.0" VBox.vgrow="ALWAYS">
               <content>
                  <VBox fx:id="shapeVBox" spacing="2.0">
                     <padding>
                        <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
                     </padding>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
         <padding>
            <Insets left="3.0" right="3.0" />
         </padding>
      </VBox>
   </items>
</SplitPane>
